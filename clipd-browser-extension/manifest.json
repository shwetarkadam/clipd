{
  "manifest_version": 3,
  "name": "Clipd — Link Slot Copy",
  "version": "1.0.0",
  "description": "Hover a link, press ⌘⇧+1–9 (Mac) or Ctrl⇧+1–9 (Win/Linux) to save its URL directly into a clipd slot.",

  "permissions": [
    "activeTab",
    "scripting",
    "clipboardWrite"
  ],

  "host_permissions": [
    "http://127.0.0.1:51234/*",
    "http://localhost:51234/*"
  ],

  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content_script.js"],
      "run_at": "document_start",
      "all_frames": false
    }
  ],

  "background": {
    "service_worker": "background.js"
  },

  "icons": {
    "16":  "icons/icon16.png",
    "32":  "icons/icon32.png",
    "48":  "icons/icon48.png",
    "128": "icons/icon128.png"
  },

  "browser_specific_settings": {
    "gecko": {
      "id": "clipd-link-copy@clipd.dev",
      "strict_min_version": "109.0"
    }
  }
}
